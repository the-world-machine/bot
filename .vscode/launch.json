{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run bot",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/src/main.py",
			"cwd": "${workspaceFolder}",
			"justMyCode": false,
			"console": "integratedTerminal",
		},
		{
			"name": "Run textbox test server",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/src/main.py",
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"args": [
				"textboxweb"
			]
		},
		{
			"name": "Debug Script (Dynamic Prompt)",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/src/main.py",
			"console": "integratedTerminal",
			"args": [
				"script",
				"${input:scriptInput}"
			]
		},
		{
			"name": "Python Debugger: Current File",
			"type": "debugpy",
			"request": "launch",
			"program": "${file}",
			"console": "integratedTerminal"
		},
	],
	"inputs": [
		{
			"id": "scriptInput",
			"type": "promptString",
			"description": "Enter the name of the script (e.g. weblate.sync_file_structure)",
			"default": "sync_file_structure"
		}
	]
}